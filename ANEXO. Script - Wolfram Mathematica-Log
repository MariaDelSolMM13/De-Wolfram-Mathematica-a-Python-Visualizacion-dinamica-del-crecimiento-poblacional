(* --- BLOQUE 0: DEFINICIÓN DE VARIABLES Y FUNCIONES --- *)

(* 1. Definimos la Solución Analítica (Ecuación Integrada) *)
logisticaN[t_, r_, k_, n0_] := k / (1 + ((k - n0) / n0) * Exp[-r * t]);

(* 2. Definimos la Ecuación de Velocidad (Derivada) *)
velocidadLog[n_, r_, K_] := r * n * (1 - n / K);

(* 3. Estilo Gráfico Unificado *)
estiloGrafico = {
  Frame -> True, 
  FrameStyle -> Directive[Black, Thickness[0.002]], 
  LabelStyle -> {FontFamily -> "Arial", 14, Black}, 
  GridLines -> Automatic, 
  ImageSize -> Medium
};

Print["Modelo matemático y estilos cargados exitosamente."];


(* --- BLOQUE 1: FAMILIA DE CURVAS (EFECTO DE "r") --- *)

Kval = 100; 
noval = 5; 
tiempoMax = 25;

Plot[{
  logisticaN[t, 0.2, Kval, noval], 
  logisticaN[t, 0.5, Kval, noval], 
  logisticaN[t, 1.0, Kval, noval]
 }, {t, 0, tiempoMax}, 
 PlotStyle -> {
  {Blue, Thickness[0.007]}, 
  {Orange, Thickness[0.007], Dashed}, 
  {Red, Thickness[0.007]}
 }, 
 PlotLegends -> {"r = 0.2 (Lento)", "r = 0.5 (Medio)", "r = 1.0 (Rápido)"}, 
 PlotLabel -> "Efecto de la tasa de crecimiento, r", 
 FrameLabel -> {"Tiempo (t)", "Tamaño de Población N(t)"}, 
 PlotRange -> {{0, tiempoMax}, {0, Kval * 1.2}}, 
 Epilog -> {
  Red, Dashed, Thickness[0.005], 
  Line[{{0, Kval}, {tiempoMax, Kval}}], 
  Text[Style["Capacidad de Carga K", Red, Background -> White], {tiempoMax / 2, Kval + 5}]
 }, 
 Evaluate[estiloGrafico]
]


(* --- BLOQUE 2: RELACIÓN POBLACIÓN vs. VELOCIDAD --- *)

rDemo = 0.8; 
KDemo = 100;

Plot[velocidadLog[n, rDemo, KDemo], {n, 0, KDemo * 1.1}, 
 PlotStyle -> {Purple, Thickness[0.008]}, 
 Filling -> Axis, 
 FillingStyle -> Opacity[0.2, Purple], 
 PlotLabel -> "La velocidad cae a cero cuando alcanzamos K", 
 FrameLabel -> {"Población Actual (N)", "Velocidad de Crecimiento (dN/dt)"}, 
 Epilog -> {
  (* Marcador del punto máximo de velocidad *)
  Green, PointSize[0.02], Point[{KDemo / 2, velocidadLog[KDemo / 2, rDemo, KDemo]}], 
  Text[Style["Máxima Vel. (K/2)", Darker[Green]], {KDemo / 2, velocidadLog[KDemo / 2, rDemo, KDemo] * 1.1}], 
  (* Marcador de K *)
  Red, Dashed, Thickness[0.005], Line[{{KDemo, 0}, {KDemo, 10}}], 
  Text[Style["Fin del Crecimiento\n (N=K)", Red], {KDemo, 15}]
 }, 
 Evaluate[estiloGrafico]
]


